# Application
APP_NAME=My Computer
APP_VERSION=1.6.0
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-secret-key

# Database
# Local dev (pgserver): postgresql+asyncpg://postgres@127.0.0.1:5432/postgres
# Docker: postgresql+asyncpg://mycomputer:mycomputer@postgres:5432/mycomputer
DATABASE_URL=postgresql+asyncpg://postgres@127.0.0.1:5432/postgres

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ChromaDB (embedded fallback if unavailable)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=mycomputer

# LLM provider: auto | mock | openai | anthropic | grok
# auto = try LLM_FALLBACK_CHAIN in order
LLM_PROVIDER=auto
LLM_FALLBACK_CHAIN=openai,anthropic,grok,mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GROK_API_KEY=
GROK_MODEL=grok-2-latest

# Embeddings: hash | sentence-transformers | openai
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Webhooks
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# Meta-agent (v2.0 self-improvement)
META_AGENT_ENABLED=true
META_AGENT_SOURCE_ROOT=/home/lukpak/my-computer
META_AGENT_REQUIRE_APPROVAL=true

# CORS
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]